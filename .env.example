# Laptop Momentum — Secrets / Environment Configuration
# Copy this to .env and fill in your values.
# DO NOT commit .env to version control.

# ntfy.sh topic for phone alerts (subscribe on phone)
NTFY_TOPIC=your-random-topic-here

# ntfy.sh topic for heartbeats (GitHub Actions reads this, phone doesn't)
NTFY_STATUS_TOPIC=your-status-topic-here
